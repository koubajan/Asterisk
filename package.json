{
  "name": "asterisk",
  "productName": "Asterisk",
  "version": "1.4.6",
  "description": "A dark Markdown note editor",
  "main": "./out/main/index.js",
  "author": "Jan Kouba",
  "license": "SEE LICENSE IN LICENSE",
  "build": {
    "appId": "com.asterisk.app",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**",
      "!out/**/*.map"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/macos_icon.icns"
    },
    "win": {
      "icon": "resources/windows_icon.ico"
    },
    "linux": {
      "icon": "resources/linux_icon.png"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild:sharp": "electron-rebuild -f -w sharp"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@codemirror/autocomplete": "^6.18.4",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.3",
    "@excalidraw/excalidraw": "^0.18.0",
    "@google/generative-ai": "^0.24.1",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "diff": "^8.0.3",
    "dompurify": "^3.2.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.7",
    "mermaid": "^11.13.0",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/d3": "^7.4.3",
    "@types/dagre": "^0.7.54",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
